{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "AnySchool.ai",
  "colors": {
    "primary": "#007799",
    "light": "#5d8f9c",
    "dark": "#166473"
  },
  "favicon": {
    "light": "/favicon_dark.svg",
    "dark": "/favicon_dark.svg"
  },
  "navigation": {
    "pages": [
      {
        "group": "Excursions",
        "icon": "bus",
        "expanded": true,
        "pages": [
          "excursions",
          {
            "group": "Excursion Features",
            "pages": [
              "overview-tab",
              "activity-tab",
              "timeline-tab",
              "participants-tab",
              "staffing-tab",
              "tasks-tab",
              "emails-tab",
              "documents-tab",
              "forms-tab",
              "website-tab",
              "risk-management-tab",
              "transport-tab",
              "reviews-tab",
              "settings-tab"
            ],
            "expanded": true
          }
        ]
      },
      "dashboard",
      {
        "group": "Features",
        "pages": [
          {
            "group": "Tasks",
            "root": "tasks",
            "icon": "diagram-subtask",
            "pages": ["workspace-tasks", "task-overlay"]
          },
          {
            "group": "Forms",
            "root": "forms",
            "icon": "clipboard-question",
            "pages": ["forms-list", "form-builder"]
          },
          {
            "group": "Locations",
            "root": "locations",
            "icon": "map",
            "pages": ["locations-list", "locations-import"]
          },
          {
            "group": "Vendors",
            "root": "vendors",
            "icon": "shop",
            "pages": ["vendors-list", "vendor-details-modal"]
          },
          {
            "group": "Staff",
            "root": "staff",
            "icon": "user-doctor-hair-long",
            "pages": ["staff-directory", "staff-member-summary"]
          },
          {
            "group": "Groups",
            "root": "groups",
            "icon": "people-group",
            "pages": ["groups-list", "group-detail"]
          },
          {
            "group": "Students",
            "root": "students",
            "icon": "user-graduate",
            "pages": [
              "students-list",
              "student-upsert-modal",
              "students-import",
              "parent-student-relationships"
            ]
          },
          {
            "group": "Risk bank",
            "root": "risk-bank",
            "icon": "biohazard",
            "pages": ["risk-bank-page", "risk-bank-tree", "risk-bank-modals"]
          },
          {
            "group": "Parents",
            "root": "parents",
            "icon": "users",
            "pages": ["parents-list", "parent-upsert-modal", "parents-import"]
          }
        ]
      },
      "changelog"
    ]
  },
  "logo": {
    "light": "/logo_text_light_2.svg",
    "dark": "/logo_text_dark_2.svg",
    "href": "/"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@karstack.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/mintlify"
    }
  },
  "description": "The Excursion Management Platform",
  "fonts": {
    "family": "Geist"
  },
  "metadata": {
    "timestamp": true
  },
  "seo": {
    "indexing": "all"
  }
}
