{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "AnySchool.ai",
  "colors": {
    "primary": "#007799",
    "light": "#5d8f9c",
    "dark": "#166473"
  },
  "favicon": {
    "light": "/favicon_dark.svg",
    "dark": "/favicon_dark.svg"
  },
  "navigation": {
    "pages": [
      "dashboard",
      {
        "group": "Tasks",
        "pages": [
          "tasks",
          {
            "group": "Task screens",
            "pages": ["workspace-tasks", "task-overlay"]
          }
        ],
        "icon": "diagram-subtask"
      },
      {
        "group": "Forms",
        "pages": [
          "forms",
          {
            "group": "Form screens",
            "pages": ["forms-list", "form-builder"]
          }
        ],
        "icon": "clipboard-question"
      },
      {
        "group": "Locations",
        "pages": [
          "locations",
          {
            "group": "Location screens",
            "pages": ["locations-list", "locations-import"]
          }
        ],
        "icon": "map"
      },
      {
        "group": "Vendors",
        "pages": [
          "vendors",
          {
            "group": "Vendor screens",
            "pages": ["vendors-list", "vendor-details-modal"]
          }
        ],
        "icon": "shop"
      },
      {
        "group": "Staff",
        "pages": [
          "staff",
          {
            "group": "Staff screens",
            "pages": ["staff-directory", "staff-member-summary"]
          }
        ],
        "icon": "user-doctor-hair-long"
      },
      {
        "group": "Groups",
        "pages": [
          "groups",
          {
            "group": "Group screens",
            "pages": ["groups-list", "group-detail"]
          }
        ],
        "icon": "people-group"
      },
      {
        "group": "Students",
        "pages": [
          "students",
          {
            "group": "Student screens",
            "pages": [
              "students-list",
              "student-upsert-modal",
              "students-import",
              "parent-student-relationships"
            ]
          }
        ],
        "icon": "user-graduate"
      },
      {
        "group": "Parents",
        "pages": [
          "parents",
          {
            "group": "Parent screens",
            "pages": ["parents-list", "parent-upsert-modal", "parents-import"]
          }
        ],
        "icon": "users"
      },
      {
        "group": "Risk bank",
        "pages": [
          "risk-bank",
          {
            "group": "Risk bank screens",
            "pages": ["risk-bank-page", "risk-bank-tree", "risk-bank-modals"]
          }
        ],
        "icon": "biohazard"
      },
      "changelog",
      {
        "group": "Excursions",
        "pages": [
          "excursions",
          {
            "group": "Excursion Features",
            "pages": [
              "overview-tab",
              "activity-tab",
              "timeline-tab",
              "participants-tab",
              "staffing-tab",
              "tasks-tab",
              "emails-tab",
              "documents-tab",
              "forms-tab",
              "website-tab",
              "risk-management-tab",
              "transport-tab",
              "reviews-tab",
              "settings-tab"
            ],
            "expanded": true
          }
        ],
        "icon": "bus",
        "expanded": true
      }
    ]
  },
  "logo": {
    "light": "/logo_text_light_2.svg",
    "dark": "/logo_text_dark_2.svg",
    "href": "/"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@karstack.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/mintlify"
    }
  },
  "description": "The Excursion Management Platform",
  "fonts": {
    "family": "Geist"
  },
  "metadata": {
    "timestamp": true
  },
  "seo": {
    "indexing": "all"
  }
}
